[Unit]
Description=AtomTap Ethernet-to-WiFi traffic mirror
After=network-online.target atomtap-firstboot-setup.service
Wants=network-online.target atomtap-firstboot-setup.service
ConditionPathExists=/var/lib/atomtap/firstboot.done

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/usr/local/sbin/atomtap-forward.sh start
ExecStop=/usr/local/sbin/atomtap-forward.sh stop

[Install]
WantedBy=multi-user.target
