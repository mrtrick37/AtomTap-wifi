# First-boot setup timeout in seconds.
# 0 disables timeout (wait forever for console input).
FIRSTBOOT_TIMEOUT_SEC=0

# Action when timeout is reached:
#   reboot  -> reboot device (recommended for unattended deployments)
#   poweroff -> power off device
#   fail    -> exit setup service with failure
FIRSTBOOT_ON_TIMEOUT=reboot

# Default local admin created before setup starts.
# You can change username/password in the first-boot menu.
DEFAULT_ADMIN_USER=atomtap
DEFAULT_ADMIN_PASSWORD=atomtap

# Curses dialog title shown during first-boot setup.
SETUP_TITLE="AtomTap First-Boot Setup"
