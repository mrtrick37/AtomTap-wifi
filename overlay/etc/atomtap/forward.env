# Interface receiving OT traffic (often a SPAN/mirror port)
ETH_IFACE=eth0

# Wi-Fi uplink interface used to transport mirrored traffic
WIFI_IFACE=wlan0

# Remote collector endpoint for mirrored VXLAN traffic
COLLECTOR_IP=

# Static IPv4 configuration for Wi-Fi uplink interface
WLAN_IPV4_CIDR=
WLAN_IPV4_GATEWAY=

# VXLAN settings (must match collector)
VXLAN_ID=4096
VXLAN_PORT=4789
