# Interface receiving OT traffic (often a SPAN/mirror port)
ETH_IFACE=eth0

# Wi-Fi uplink interface used to transport mirrored traffic
WIFI_IFACE=wlan0

# Wi-Fi credentials configured during first-boot setup
WLAN_SSID=
WLAN_PSK=

# Remote collector endpoint for mirrored traffic
COLLECTOR_IP=

# Wi-Fi IPv4 configuration for uplink interface
WLAN_IPV4_MODE=dhcp
WLAN_IPV4_ADDRESS=
WLAN_IPV4_SUBNET=
WLAN_IPV4_CIDR=
WLAN_IPV4_GATEWAY=
